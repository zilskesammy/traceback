# .env.example — Alle benötigten Environment Variables für Traceback
# Kopiere diese Datei zu .env.local und fülle alle Werte aus.
# NIEMALS .env.local in Git committen.

# ─── DATENBANK (Vercel Postgres) ─────────────────────────────────────────────

# Prisma-kompatibler Connection String (mit pgbouncer=true für Connection Pooling)
# Zu finden im Vercel Dashboard unter Storage → Postgres → .env.local
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connect_timeout=15"

# Direkte Verbindung ohne Pooling — wird von Prisma Migrate benötigt
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?connect_timeout=15"

# ─── NEXTAUTH v5 ─────────────────────────────────────────────────────────────

# Zufälliger 32-Byte String zum Signieren von Session-Tokens
# Generieren: openssl rand -base64 32
NEXTAUTH_SECRET="dein-geheimer-32-zeichen-string"

# Vollständige URL der App (kein trailing slash)
# Lokal: http://localhost:3000 | Produktion: https://traceback.app
NEXTAUTH_URL="http://localhost:3000"

# ─── GITHUB OAUTH APP (für User-Login) ───────────────────────────────────────

# GitHub OAuth App erstellen unter: github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="Ov23liXXXXXXXXXXXXXX"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# ─── GITHUB APP (für Repository-Integration + Webhooks) ──────────────────────

# Numerische ID der GitHub App (zu finden unter App-Einstellungen)
GITHUB_APP_ID="12345"

# Private Key der GitHub App — wird zum Signieren von JWT Installation Tokens verwendet
# Generieren: Im GitHub App Dashboard → "Generate a private key"
# Zeilenumbrüche durch \n ersetzen für .env:
# cat traceback.private-key.pem | tr '\n' '\n'
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"

# URL-Slug der GitHub App (z.B. "traceback" → github.com/apps/traceback)
GITHUB_APP_SLUG="traceback"

# ─── WEBHOOK SICHERHEIT ──────────────────────────────────────────────────────

# Shared Secret für globale HMAC SHA-256 Webhook-Signaturprüfung
# Generieren: openssl rand -hex 32
# Wird beim Registrieren des Webhooks an GitHub übergeben
WEBHOOK_SECRET="dein-zufaelliger-webhook-secret"

# ─── APP URL (öffentlich, für Invite-Links + Webhooks) ───────────────────────

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── LOCAL AGENT ─────────────────────────────────────────────────────────────

# API Key from your Traceback project (Settings → API Keys)
TRACEBACK_API_KEY="tb_xxxxxxxxxxxxxxxxxxxxx"

# Your Traceback project ID (from the URL: /projects/<id>)
TRACEBACK_PROJECT_ID="your-project-id"

# Traceback server URL (production or local)
TRACEBACK_URL="https://traceback-hazel.vercel.app"

# Directory of the repository to work in (defaults to current directory)
REPO_DIR="/path/to/your/repo"
